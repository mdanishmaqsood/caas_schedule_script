CAAS_EMAIL=
CAAS_PASSWORD=
CAAS_BASE_URL=https://prod.bh.caas.ai/backend/api/v1
MATTERMOST_WEBHOOK_URL=

# Master switch: true = auto-accept eligible tasks; false = never auto-accept (notifications etc. unchanged)
AUTO_ACCEPT_ENABLED=true

# Auto-accept scheduling (Pakistan time)
# Days: monday,tuesday,wednesday,thursday,friday,saturday,sunday
AUTO_ACCEPT_ENABLED_DAYS=monday,tuesday,wednesday,thursday,friday,saturday,sunday

# Extended window for specific days (requested: Thursday and Friday)
AUTO_ACCEPT_EXTENDED_DAYS=thursday,friday
AUTO_ACCEPT_EXTENDED_START=06:00
AUTO_ACCEPT_EXTENDED_END=22:00

# Default window for all other days
AUTO_ACCEPT_DEFAULT_START=07:00
AUTO_ACCEPT_DEFAULT_END=17:00
